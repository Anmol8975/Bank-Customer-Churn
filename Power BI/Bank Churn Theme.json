{
  "name": "Bank Churn Executive Theme",
  "dataColors": [
    "#1E3A8A", 
    "#EF4444", 
    "#3B82F6", 
    "#F59E0B", 
    "#14B8A6", 
    "#64748B", 
    "#8B5CF6", 
    "#10B981"
  ],
  "background": "#F4F6F8",
  "foreground": "#1E293B",
  "tableAccent": "#1E3A8A",
  "visualStyles": {
    "page": {
      "*": {
        "background": [
          {
            "color": { "solid": { "color": "#F4F6F8" } },
            "transparency": 0
          }
        ]
      }
    },
    "*": {
      "*": {
        "background": [
          {
            "show": true,
            "color": { "solid": { "color": "#FFFFFF" } },
            "transparency": 0
          }
        ],
        "border": [
          {
            "show": true,
            "color": { "solid": { "color": "#FFFFFF" } },
            "radius": 8
          }
        ],
        "dropShadow": [
          {
            "show": true,
            "color": { "solid": { "color": "#0F172A" } },
            "transparency": 12,
            "position": "Outer",
            "preset": "BottomRight"
          }
        ],
        "visualHeader": [
          {
            "foreground": { "solid": { "color": "#1E293B" } }
          }
        ]
      }
    },
    "card": {
      "*": {
        "labels": [
          {
            "color": { "solid": { "color": "#1E3A8A" } }
          }
        ]
      }
    }
  },
  "textClasses": {
    "label": {
      "fontFace": "'Segoe UI', wf_segoe-ui, helvetica, arial, sans-serif",
      "color": "#64748B"
    },
    "callout": {
      "fontFace": "'Segoe UI Semibold', wf_segoe-ui_semibold, helvetica, arial, sans-serif",
      "color": "#1E3A8A"
    },
    "title": {
      "fontFace": "'Segoe UI Semibold', wf_segoe-ui_semibold, helvetica, arial, sans-serif",
      "color": "#1E293B",
      "fontSize": 12
    },
    "header": {
      "fontFace": "'Segoe UI Semibold', wf_segoe-ui_semibold, helvetica, arial, sans-serif",
      "color": "#1E293B"
    }
  }
}